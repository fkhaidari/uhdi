# Pinned fork URLs and revisions for the bench toolchain Docker image.
#
# Shell-sourceable: KEY=VALUE per line, no quotes, no `export`.
# Both `tools/Dockerfile` (via --build-arg) and `tools/compute-tag.sh`
# read this file. Bump a SHA -> recompute tools/image-tag.txt with
# `tools/compute-tag.sh > tools/image-tag.txt`, commit both -> the
# build-tools workflow will rebake and publish the new image tag.
#
# `*_URL` and `*_REV` are the only fork-specific knobs; everything
# else (CHISEL_STOCK_VERSION, SCALA_CLI_VERSION) is a version of an
# upstream artifact that doesn't change per fork.

# CIRCT fork carrying the --emit-uhdi pass (branch: fk-sc/uhdi-pool).
CIRCT_URL=https://github.com/fkhaidari/circt.git
CIRCT_REV=156f0ee73dc4e50203aead1c0d40f339553b68b4

# LLVM revision used by the CIRCT fork (matches circt's llvm/ submodule).
LLVM_URL=https://github.com/llvm/llvm-project.git
LLVM_REV=e89a4dfabfac7016819d201dacb6c6c58e6a2365

# hgdb-circt fork (LLVM-16 era; --hgdb=<file> flag, branch: dev/debug).
HGDB_CIRCT_URL=https://github.com/fkhaidari/hgdb-circt.git
HGDB_CIRCT_REV=41e545925273dfb13dba831f34e949aab8d57126
HGDB_CIRCT_LLVM_URL=https://github.com/llvm/llvm-project.git
HGDB_CIRCT_LLVM_REV=6f48e68d398d3dd5ffcdd9d86824cce01a6e2b3c

# Scala FIRRTL 1.x assembly producing hgdb-firrtl.jar (branch: master).
HGDB_FIRRTL_URL=https://github.com/fkhaidari/hgdb-firrtl.git
HGDB_FIRRTL_REV=a6ead083d55b4e057efc92e8beee9027aaf07c92

# hgdb runtime: toml2hgdb script + _hgdb python C extension
# (branch: fk-sc/uhdi).
HGDB_URL=https://github.com/fkhaidari/hgdb.git
HGDB_REV=4b2b83a8260e559032cf203dffae558bd2f6c321

# Chisel forks (mill publishLocal'd into ~/.ivy2/local/).
# tywaves: rameloni's chisel fork on tywaves-develop.
CHISEL_TYWAVES_URL=https://github.com/rameloni/chisel.git
CHISEL_TYWAVES_REV=a713fdaf5214770dad7d3631bd1d500fd1f623bf
# uhdi: fkhaidari/chisel on fk-sc/debug-info -- adds debug intrinsics
# on top of the tywaves SNAPSHOT, same artifact name.
CHISEL_UHDI_URL=https://github.com/fkhaidari/chisel.git
CHISEL_UHDI_REV=d8ed90a4ac020aebec40f6e5b4afa3e0838c4db1

# Surfer fork carrying tywaves rendering (branch: tywaves-develop).
# Mirrored from gitlab.com/rameloni/surfer-tywaves-demo so the pinned
# SHA stays reachable even if upstream is renamed/archived.
TYWAVES_URL=https://github.com/fkhaidari/surfer-tywaves.git
TYWAVES_REV=6b7b8dd54fa7b1fa47e421a5bbca5237771e7cd7

# Stable downstream tool versions (not built from source).
SCALA_CLI_VERSION=1.5.4
CHISEL_STOCK_VERSION=6.4.0
