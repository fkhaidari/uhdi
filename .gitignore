__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# coverage.py runtime data (`coverage run` writes .coverage; --parallel
# adds .coverage.<host>.<pid>.<rand>; coverage xml -o coverage.xml).
.coverage
.coverage.*
coverage.xml
htmlcov/

# Converter outputs.  Test fixtures live under
# converter/test/fixtures/ and are meant to be tracked -- the
# un-ignore lines below override the glob.
*.uhdi.json
*.dd
*.db
*.sv
!converter/test/fixtures/**/*.uhdi.json
!converter/test/fixtures/**/*.dd
!converter/test/fixtures/**/*.db
!demo/*/tb.sv

# demo/<name>/.bin/firtool downloaded per-demo by run.sh; demo/<name>/out/
# is mill's build output (per-machine, not source-of-truth).
demo/*/.bin/
demo/*/out/

# bench scala-cli FIR cache.  Re-derivable from `bench/fixtures/*.scala`,
# expensive to re-fetch (chisel deps), but per-machine.
bench/.cache/

# scala-cli BSP / build-server data.  scala-cli drops these next to
# any source it compiles; they're machine-specific class files and
# bloop session caches, not source-of-truth.
bench/fixtures/.bsp/
bench/fixtures/.scala-build/

# demo.sh outputs
demo-out-*/
*.vcd

# compare scripts' workdir
.cmp/

# Editor
.idea/
*.swp

.vscode/
